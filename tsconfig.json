{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "moduleSuffixes": [
      ".ios",
      ".android",
      ".native",
      ".web",
      ""
    ],
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ],
      "react-native-gifted-chat": [
        "./types/react-native-gifted-chat"
      ],
      "react-native-syntax-highlighter": [
        "./types/react-native-syntax-highlighter"
      ],
      "react-syntax-highlighter/styles/hljs": [
        "./types/react-syntax-highlighter-hljs"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
